{
  "name": "tracker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "esbuild src/index.ts --bundle --minify --target=es2017 --outfile=../../packages/dashboard/public/tracker.js --format=iife --global-name=CausalFunnelTracker",
